<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E1A">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0F1626"
        android:padding="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Back"
            android:textColor="#00D4FF"
            android:textSize="12sp"
            android:backgroundTint="#1A2744"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <TextView
            android:id="@+id/tvGridTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="4×4 — Medium"
            android:textColor="#00FF88"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnShuffle"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="🔀 Shuffle"
            android:textColor="#00FF88"
            android:textSize="12sp"
            android:backgroundTint="#1A2744"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- STATS ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvMoves"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Moves: 0"
            android:textColor="#00D4FF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏱ 00:00"
            android:textColor="#FFD700"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- DIVIDER -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1A2744"/>

    <!-- PUZZLE GRID (populated programmatically) -->
    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="16dp"/>

    <!-- BOTTOM HINT -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap tiles to slide them into place · Arrange all EEE symbols in order!"
        android:textColor="#334455"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="12dp"/>

</LinearLayout>